# Build output
dist/

# Dependencies
node_modules/

# bible_base.sqlite3 is 63 MB — exceeds Cloudflare Pages 25 MB file limit.
# Use the chunks in public/db/chunks/bible_base/ instead (committed below).
public/db/bible_base.sqlite3

# Commentaries DB is 299 MB — too large for Cloudflare Pages or git. Skip for now.
public/db/commentaries.sqlite3

# lxx and harmony DBs not yet built
public/db/lxx.sqlite3
public/db/harmony.sqlite3

# WAL/SHM temp files
public/db/*.sqlite3-shm
public/db/*.sqlite3-wal

# All other DBs (≤25 MB) and chunks are committed — Cloudflare Pages serves them.

# WebAssembly — committed (copied from node_modules, needed at runtime)
# public/sql-wasm.wasm
# public/sqlite.worker.js

# Fonts — committed (self-hosted, required at runtime)
# public/fonts/

# Source data (large downloads — not part of the codebase)
scripts/source-data/

# Repomix snapshot (generated before each session — not committed)
repomix-snapshot.xml
repomix-output.*

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Logs
*.log
npm-debug.log*

# Environment
.env
.env.local

# Claude Code local settings (keep project settings.json, not local overrides)
.claude/settings.local.json

# MCP config contains local absolute paths — not portable between machines
.mcp.json
CLAUDE.md
BUILD_STATUS.md
docs/
repomix-snapshot.xml
